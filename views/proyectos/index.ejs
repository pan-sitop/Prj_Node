<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0 text-primary">Lista de Proyectos</h3>
    <a href="/proyectos/crear" class="btn btn-primary shadow-sm"><i class="bi bi-plus-lg"></i> Nuevo Proyecto</a>
</div>

<div class="card overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th class="py-3 px-4">ID</th>
                    <th class="py-3 px-4">Proyecto</th>
                    <th class="py-3 px-4">Descripción</th>
                    <th class="py-3 px-4">Cliente</th>
                    <th class="py-3 px-4">Estado</th>
                    <th class="py-3 px-4 text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
            <% proyectos.forEach((p)=>{ %>
                <tr>
                    <td class="px-4 text-muted">#<%= p.id %></td>
                    <td class="px-4 fw-semibold"><i class="bi bi-folder2-open text-primary me-2"></i><%= p.nombre %></td>
                    <td class="px-4"><small class="text-muted"><%= p.descripcion %></small></td>
                    <td class="px-4"><%= p.cliente %></td>
                    <td class="px-4"><span class="badge bg-secondary"><%= p.estado %></span></td>
                    <td class="px-4 text-center">
                        <a href="/proyectos/editar/<%= p.id %>" class="btn btn-sm btn-outline-warning border-0"><i class="bi bi-pencil-square"></i></a>
                        <a href="/proyectos/eliminar/<%= p.id %>" class="btn btn-sm btn-outline-danger border-0" onclick="return confirm('¿Eliminar?');"><i class="bi bi-trash3"></i></a>
                    </td>
                </tr>
            <% }) %>
            </tbody>
        </table>
    </div>
</div>
<%- include('../partials/footer') %>